# Sonda ST7701 — config de plataforma de la Waveshare P4 4.3" (copiada de su sdkconfig.defaults).
CONFIG_IDF_TARGET="esp32p4"

# Revision de silicio: IGUAL que la Function-EV. Sin esto el flash falla por revision.
CONFIG_ESP32P4_SELECTS_REV_LESS_V3=y
CONFIG_ESP32P4_REV_MIN_1=y

# Flash (16MB basta para la sonda; funciona aunque la placa tenga 32MB).
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_SPI_FLASH_SUPPORT_GD_CHIP=y

# PSRAM: el framebuffer del DPI (480x800x2 = 750 KB) no cabe en RAM interna.
CONFIG_SPIRAM=y
CONFIG_SPIRAM_SPEED_200M=y
CONFIG_SPIRAM_XIP_FROM_PSRAM=y
CONFIG_CACHE_L2_CACHE_256KB=y
CONFIG_CACHE_L2_CACHE_LINE_128B=y

# La Waveshare activa features experimentales (MIPI-DSI helpers).
CONFIG_IDF_EXPERIMENTAL_FEATURES=y

CONFIG_ESP_MAIN_TASK_STACK_SIZE=10240

# OJOS del bring-up: consola por UART0 => logs por COM15 (la placa no tiene Ethernet).
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
