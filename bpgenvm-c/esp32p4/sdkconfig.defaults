# ESP32-P4-Function-EV-Board, silicon rev v1.0 (tirada temprana).
#
# Sin esto, ESP-IDF v6.0.1 compila para v3.x y el flash falla con
# "bootloader requires chip revision in range [v3.0-v3.99]". Targeteamos
# las P4 < v3 (queda Min v0.0 / Max v1.99 → encaja v1.0). Ver memoria
# esp32-p4-bringup. NO usar --force (v1.x y v3.x no comparten imagen).
CONFIG_ESP32P4_SELECTS_REV_LESS_V3=y
CONFIG_ESP32P4_REV_MIN_0=y

# Holgura de stack para app_main.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# G2 — PSRAM 32 MB (HEX, 200 MHz) para el framebuffer del display. Misma config que
# el ejemplo oficial mipi_dsi del P4. PSRAM@200M y el RMII de Ethernet COEXISTEN en
# placa (el conflicto del MPLL #18377 no nos afecta — verificado).
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_HEX=y
CONFIG_SPIRAM_SPEED_200M=y

# RAM — baja el umbral de "siempre interno" de 16 KiB (default IDF) a 2 KiB: los
# objetos LVGL y demás allocs de 2–16 KiB pasan a PSRAM y liberan SRAM interna (la
# escasa). La PSRAM del P4 es rápida (HEX@200) → penalización baja, ×8 más margen
# de objetos pequeños. NB: como es un CONFIG_, sólo aplica al regenerar el
# sdkconfig (idf.py reconfigure, o borrar el sdkconfig).
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=2048

# G4 — la flash REAL es de 16 MB (el chip), no 2 MB. Sin esto IDF compila para 2 MB:
# la imagen con LVGL no cabe en el app de 1 MB de la tabla single-app, y avisa
# "Detected size(16384k) larger than image header(2048k)". Tabla a medida
# (partitions.csv): app de 4 MB + bpfs (FS persistente). Espeja el firmware del S3.
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="16MB"
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
