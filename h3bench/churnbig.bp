module ChurnBig

    // H3-A (VM-C) test de REUSO: 50000 arrays que mueren (solo el último vivo).
    // 50000 * ~88 B = ~4.4 MB >> heap (~254 KB). Con bump-sin-reuse OOM-earía
    // a los ~2500; con free-list+reuso debe completar.

    function Main()
        var i: integer := 0
        var last: integer[] := newIntArray(1)
        while i < 50000 do
            last := newIntArray(20)
            i := i + 1
        endwh
        print "done", 50000, last[0]
    end Main

end ChurnBig
