# ============================================================
# Build outputs (Maven)
# ============================================================
target/
*.class

# Maven status / dependency-reduced poms
**/dependency-reduced-pom.xml

# ============================================================
# IDE / editor metadata
# ============================================================
.idea/
.vscode/
*.iml
nbproject/private/
nb-configuration.xml
.classpath
.project
.settings/

# ============================================================
# OS noise
# ============================================================
Thumbs.db
.DS_Store

# ============================================================
# Compilation artifacts en samples/
# ============================================================
# Los .mod/.bpi/.dbg de lexer-java/samples/ son recompilables
# en cualquier momento; los excluímos para que el repo no se
# llene de binarios que cambian con cada compilación.
# NOTA: lo de bpstdlib/ sí va al repo — es la distribución
# del stdlib.
lexer-java/samples/*.mod
lexer-java/samples/*.bpi
lexer-java/samples/*.dbg
lexer-java/samples/**/out/*.mod
lexer-java/samples/**/out/*.bpi
lexer-java/samples/**/out/*.dbg
lexer-java/samples/**/*.class

# Dir de outputs de compilaciones ad-hoc del frontend
lexer-java/out/

# Stray outputs de tests
out_test.txt
tmp_iotest/

# ============================================================
# Claude Code (caché local de permisos por carpeta)
# ============================================================
.claude/settings.local.json
**/.claude/settings.local.json

# ============================================================
# Dependencias externas grandes (vendored / submodule candidates)
# ============================================================
# FreeRTOS-Kernel y FreeRTOS-LTS van con el SDK del Pico, fuera del repo.
FreeRTOS-Kernel/
FreeRTOS-LTS/
FreeRTOSv202604.00-LTS.zip
# Pico SDK: idem.
pico-sdk/

# ============================================================
# Outputs ad-hoc y prefs del IDE
# ============================================================
out/
BpIde/.bpide-prefs

# ============================================================
# Build artefacts del firmware Pico y de bpgenvm-c
# ============================================================
bpgenvm-c/pico/build/
bpgenvm-c/pico/mdn_build/
bpgenvm-c/build/
bpgenvm-c/samples/*.mod
bpgenvm-c/samples/*.bpi
bpgenvm-c/samples/*.dbg

# Outputs locales del IDE/runs en samples/
samples/out/

# ============================================================
# Outputs ad-hoc del AOT/MdnPack en lexer-java
# ============================================================
lexer-java/*.mdn
lexer-java/*.o
lexer-java/aotout/

# ============================================================
# samples/ — outputs de compilación (la fuente son los .bp;
# .mod/.bpi/.dbg/.mdn se recompilan). NOTA: bpstdlib/ SÍ se versiona.
# ============================================================
samples/*.mod
samples/*.bpi
samples/*.dbg
samples/*.mdn

# .mod sueltos de demos ad-hoc en la raíz del repo
/*.mod

# Scratch temporal
/Temp/

# CMake in-source del firmware Pico + outputs de build STM32
bpgenvm-c/pico/CMakeCache.txt
bpgenvm-c/pico/CMakeFiles/
bpgenvm-c/stm32/**/*.bpi
bpgenvm-c/stm32/**/*.dbg

# Logs de samples (LogTest, etc.)
samples/*.log
samples/*.log.old
